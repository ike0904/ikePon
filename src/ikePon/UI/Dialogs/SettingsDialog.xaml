<Window x:Class="ikePon.UI.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Width="360" SizeToContent="Height"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#CCCCCC">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- フェード設定 -->
        <TextBlock Text="フェード設定" FontWeight="Bold" FontSize="12"
                   Foreground="#AAAAAA" Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="短いフェード（即時停止）" Grid.Column="0"/>
            <TextBox  x:Name="TbShortFade" Grid.Column="1"/>
            <Label    Content="秒" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="長いフェードアウト" Grid.Column="0"/>
            <TextBox  x:Name="TbLongFade" Grid.Column="1"/>
            <Label    Content="秒" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <Separator Background="#383838" Margin="0,8"/>

        <!-- インターロック -->
        <TextBlock Text="インターロック" FontWeight="Bold" FontSize="12"
                   Foreground="#AAAAAA" Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="連打防止時間" Grid.Column="0"/>
            <TextBox  x:Name="TbInterlock" Grid.Column="1"/>
            <Label    Content="ms" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <Separator Background="#383838" Margin="0,8"/>

        <!-- オーディオ設定 -->
        <TextBlock Text="オーディオ設定" FontWeight="Bold" FontSize="12"
                   Foreground="#AAAAAA" Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="WASAPIレイテンシ" Grid.Column="0"/>
            <TextBox  x:Name="TbLatency" Grid.Column="1"/>
            <Label    Content="ms" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="プリロード上限" Grid.Column="0"/>
            <TextBox  x:Name="TbPreload" Grid.Column="1"/>
            <Label    Content="秒" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <TextBlock Text="※ オーディオ設定の変更はアプリ再起動後に反映されます。"
                   FontSize="10" Foreground="#666" Margin="0,2,0,0" TextWrapping="Wrap"/>

        <Separator Background="#383838" Margin="0,12"/>

        <!-- OK / キャンセル -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOk" Content="OK" Width="80" Margin="0,0,8,0"
                    Click="BtnOk_Click"
                    Background="#1C446E" BorderBrush="#3A9FFF" Foreground="White"
                    Padding="0,4" Cursor="Hand"/>
            <Button x:Name="BtnCancel" Content="キャンセル" Width="80"
                    Click="BtnCancel_Click"
                    Background="#3C3C3C" BorderBrush="#555" Foreground="#CCC"
                    Padding="0,4" Cursor="Hand"/>
        </StackPanel>

    </StackPanel>
</Window>
