<Window x:Class="ikePon.UI.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Width="480" SizeToContent="Height"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#CCCCCC"
        PreviewMouseDown="Window_MouseDown">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- コンボボックス（ダーク） -->
        <Style TargetType="ComboBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M 2 0 L 6 5 L 10 0"
                                                      Stroke="#AAAAAA" StrokeThickness="1.5" Fill="Transparent"
                                                      VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              IsHitTestVisible="False"
                                              Margin="5,0,20,0"
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border Background="#2E2E2E" BorderBrush="#555" BorderThickness="1">
                                    <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A7FC1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C446E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- SharedSizeScope で入力欄・単位列の横位置を全行で揃える -->
    <StackPanel Margin="16" Grid.IsSharedSizeScope="True">

        <!-- ムービー画面設定 -->
        <TextBlock Text="ムービー画面設定" FontWeight="Bold" FontSize="12"
                   Foreground="#AAAAAA" Margin="0,0,0,8"/>

        <TextBlock Text="スタンバイ画像" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TbMovieStandby"
                     Grid.Column="0"
                     IsReadOnly="True"
                     Width="Auto"
                     HorizontalAlignment="Stretch"
                     AllowDrop="True"
                     PreviewDragOver="TbMovieStandby_PreviewDragOver"
                     Drop="TbMovieStandby_Drop"
                     Cursor="Arrow"
                     VerticalContentAlignment="Center"
                     Padding="4,2"/>
            <Button x:Name="BtnClearMovieStandby"
                    Grid.Column="1"
                    Content="×"
                    Width="28" Height="22"
                    Margin="4,0,0,0"
                    FontSize="12"
                    Click="BtnClearMovieStandby_Click"
                    Background="#3C3C3C" BorderBrush="#555" Foreground="#CCC"
                    Padding="0"/>
        </Grid>
        <TextBlock Text="※ 動画非再生時にムービーウィンドウへ表示する静止画。未設定は黒画面。"
                   FontSize="10" Foreground="#666" Margin="0,0,0,6" TextWrapping="Wrap"/>

        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="InputCol"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitCol"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="スタンバイ画像フェードイン" Grid.Column="0"/>
            <TextBox x:Name="TbStandbyFadeIn" Grid.Column="1"
                     KeyDown="NumericBox_KeyDown" LostFocus="NumericBox_LostFocus"
                     PreviewMouseDown="NumericBox_MouseDown" PreviewMouseMove="NumericBox_MouseMove"
                     PreviewMouseUp="NumericBox_MouseUp" MouseWheel="NumericBox_MouseWheel"/>
            <Label Content="秒" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <Separator Background="#383838" Margin="0,8,0,8"/>

        <!-- PAセパレートモード -->
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="InputCol"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitCol"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="PAセパレートモード" Grid.Column="0"/>
            <ComboBox x:Name="CbPaSeparate" Grid.Column="1" Width="70">
                <ComboBoxItem Content="OFF"/>
                <ComboBoxItem Content="ON"/>
            </ComboBox>
            <!-- 単位列は空（他の行と横位置を合わせるためのプレースホルダ） -->
        </Grid>

        <Separator Background="#383838" Margin="0,4,0,8"/>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="InputCol"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitCol"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="フェードアウト時間" Grid.Column="0"/>
            <TextBox  x:Name="TbLongFade" Grid.Column="1"
                      KeyDown="NumericBox_KeyDown" LostFocus="NumericBox_LostFocus"
                      PreviewMouseDown="NumericBox_MouseDown" PreviewMouseMove="NumericBox_MouseMove"
                      PreviewMouseUp="NumericBox_MouseUp" MouseWheel="NumericBox_MouseWheel"/>
            <Label    Content="秒" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <Separator Background="#383838" Margin="0,8"/>

        <!-- インターロック -->
        <TextBlock Text="インターロック" FontWeight="Bold" FontSize="12"
                   Foreground="#AAAAAA" Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="InputCol"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitCol"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="連打防止時間" Grid.Column="0"/>
            <TextBox  x:Name="TbInterlock" Grid.Column="1"
                      KeyDown="NumericBox_KeyDown" LostFocus="NumericBox_LostFocus"
                      PreviewMouseDown="NumericBox_MouseDown" PreviewMouseMove="NumericBox_MouseMove"
                      PreviewMouseUp="NumericBox_MouseUp" MouseWheel="NumericBox_MouseWheel"/>
            <Label    Content="ms" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <Separator Background="#383838" Margin="0,8"/>

        <!-- オーディオ設定 -->
        <TextBlock Text="オーディオ設定" FontWeight="Bold" FontSize="12"
                   Foreground="#AAAAAA" Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="InputCol"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitCol"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="WASAPIレイテンシ" Grid.Column="0"/>
            <TextBox  x:Name="TbLatency" Grid.Column="1"
                      KeyDown="NumericBox_KeyDown" LostFocus="NumericBox_LostFocus"
                      PreviewMouseDown="NumericBox_MouseDown" PreviewMouseMove="NumericBox_MouseMove"
                      PreviewMouseUp="NumericBox_MouseUp" MouseWheel="NumericBox_MouseWheel"/>
            <Label    Content="ms" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="InputCol"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitCol"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="プリロード上限" Grid.Column="0"/>
            <TextBox  x:Name="TbPreload" Grid.Column="1"
                      KeyDown="NumericBox_KeyDown" LostFocus="NumericBox_LostFocus"
                      PreviewMouseDown="NumericBox_MouseDown" PreviewMouseMove="NumericBox_MouseMove"
                      PreviewMouseUp="NumericBox_MouseUp" MouseWheel="NumericBox_MouseWheel"/>
            <Label    Content="秒" Grid.Column="2" Margin="4,0,0,0"/>
        </Grid>

        <TextBlock Text="※ オーディオ設定の変更はアプリ再起動後に反映されます。"
                   FontSize="10" Foreground="#666" Margin="0,2,0,0" TextWrapping="Wrap"/>

        <Separator Background="#383838" Margin="0,12"/>

        <!-- OK / キャンセル -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOk" Content="OK" Width="80" Margin="0,0,8,0"
                    Click="BtnOk_Click"
                    Background="#1C446E" BorderBrush="#3A9FFF" Foreground="White"
                    Padding="0,4" Cursor="Hand"/>
            <Button x:Name="BtnCancel" Content="キャンセル" Width="80"
                    Click="BtnCancel_Click"
                    Background="#3C3C3C" BorderBrush="#555" Foreground="#CCC"
                    Padding="0,4" Cursor="Hand"/>
        </StackPanel>

    </StackPanel>
</Window>
