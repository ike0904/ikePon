<Window x:Class="ikePon.UI.Dialogs.PadDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="パッド詳細設定" Width="440" SizeToContent="Height"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#CCCCCC">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- カテゴリ -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="カテゴリ" Grid.Column="0"/>
            <ComboBox x:Name="CbCategory" Grid.Column="1">
                <ComboBoxItem Content="MOVIE"/>
                <ComboBoxItem Content="BGM"/>
                <ComboBoxItem Content="SE"/>
            </ComboBox>
        </Grid>

        <!-- 示名 -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="示名" Grid.Column="0"/>
            <TextBox x:Name="TbDisplayName" Grid.Column="1"/>
        </Grid>

        <Separator Background="#383838" Margin="0,4,0,10"/>

        <!-- ファイル名 -->
        <TextBlock Text="ファイル名（フルパス）" Margin="0,0,0,4"/>
        <TextBox x:Name="TbFilePath"
                 IsReadOnly="True"
                 AllowDrop="True"
                 DragOver="TbFilePath_DragOver"
                 Drop="TbFilePath_Drop"
                 Margin="0,0,0,2"
                 TextWrapping="Wrap"
                 Background="#252525"
                 Foreground="#AAAAAA"
                 MinHeight="32"/>
        <TextBlock Text="別ファイルに変更: ここへドラッグ＆ドロップ"
                   FontSize="10" Foreground="#555" Margin="0,0,0,10"/>

        <Separator Background="#383838" Margin="0,0,0,10"/>

        <!-- ファイルゲイン -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ファイル・ゲイン" Grid.Column="0"/>
            <TextBox x:Name="TbFileGain" Grid.Column="1"/>
            <Label Content="（全プロジェクト共通, 1.0=標準）" Grid.Column="2" Margin="8,0,0,0"/>
        </Grid>

        <!-- パッドゲイン -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="パッド・ゲイン" Grid.Column="0"/>
            <TextBox x:Name="TbPadGain" Grid.Column="1"/>
            <Label Content="（このパッドのみ, 1.0=標準）" Grid.Column="2" Margin="8,0,0,0"/>
        </Grid>

        <Separator Background="#383838" Margin="0,4,0,10"/>

        <!-- 再生開始位置 -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="再生開始位置" Grid.Column="0"/>
            <TextBox x:Name="TbStartPos" Grid.Column="1"/>
            <Label x:Name="LblTotalTime" Content="" Grid.Column="2" Margin="8,0,0,0" FontSize="10" Foreground="#777"/>
        </Grid>

        <!-- 再生終了位置 -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="再生終了位置" Grid.Column="0"/>
            <TextBox x:Name="TbEndPos" Grid.Column="1"/>
            <Label Content="（空欄＝ファイル終端）" Grid.Column="2" Margin="8,0,0,0" FontSize="10" Foreground="#777"/>
        </Grid>

        <TextBlock Text="形式: 分:秒.1秒  例: 0:00.0  /  1:23.5"
                   FontSize="10" Foreground="#555" Margin="0,0,0,12"/>

        <Separator Background="#383838" Margin="0,0,0,12"/>

        <!-- OK / キャンセル -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOk" Content="OK" Width="80" Margin="0,0,8,0"
                    Click="BtnOk_Click"
                    Background="#1C446E" BorderBrush="#3A9FFF" Foreground="White"
                    Padding="0,4" Cursor="Hand"/>
            <Button x:Name="BtnCancel" Content="キャンセル" Width="80"
                    Click="BtnCancel_Click"
                    Background="#3C3C3C" BorderBrush="#555" Foreground="#CCC"
                    Padding="0,4" Cursor="Hand"/>
        </StackPanel>

    </StackPanel>
</Window>
