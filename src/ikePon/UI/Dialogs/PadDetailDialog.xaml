<Window x:Class="ikePon.UI.Dialogs.PadDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{StaticResource Str_Dlg_Pad_Title}" Width="440" SizeToContent="Height"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#212121" Foreground="White"
        PreviewMouseDown="Window_PreviewMouseDown"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Padding" Value="4,3"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3A5080"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- ComboBoxのカスタムテンプレート（背景色をダーク化） -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"/>
                                    <Path Grid.Column="1" x:Name="Arrow"
                                          Fill="#AAAAAA"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M 0 0 L 4 4 L 8 0 Z"/>
                                </Grid>
                            </Border>
                            <ToggleButton Grid.ColumnSpan="2"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#2E2E2E" BorderBrush="#555" BorderThickness="1"/>
                                    <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A9FFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- ファイルパス -->
        <TextBlock Text="{StaticResource Str_Dlg_Pad_FilePath}" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TbFilePath"
                     Grid.Column="0"
                     IsReadOnly="True"
                     Width="Auto"
                     HorizontalAlignment="Stretch"
                     AllowDrop="True"
                     DragOver="TbFilePath_DragOver"
                     Drop="TbFilePath_Drop"
                     Cursor="Arrow"
                     VerticalContentAlignment="Center"
                     Padding="4,2"/>
            <Button x:Name="BtnClearFilePath"
                    Grid.Column="1"
                    Content="×"
                    Width="28" Height="22"
                    Margin="4,0,0,0"
                    FontSize="12"
                    Click="BtnClearFilePath_Click"
                    Background="#3C3C3C" BorderBrush="#555" Foreground="#CCC"
                    Padding="0"/>
        </Grid>
        <TextBlock Text="{StaticResource Str_Dlg_Pad_FileHint}"
                   FontSize="10" Foreground="#AAAAAA" Margin="0,2,0,10" TextWrapping="Wrap"/>

        <Separator Background="#383838" Margin="0,0,0,10"/>

        <!-- カテゴリ -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Str_Dlg_Pad_Category}" Grid.Column="0"/>
            <ComboBox x:Name="CbCategory" Grid.Column="1"
                      Background="#2E2E2E" Foreground="#EEEEEE" BorderBrush="#555"
                      ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                      SelectionChanged="CbCategory_SelectionChanged">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2E2E2E"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEEEEE"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A5080"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                </ComboBox.Resources>
                <ComboBoxItem Content="MOVIE"/>
                <ComboBoxItem Content="BGM"/>
                <ComboBoxItem Content="SE"/>
            </ComboBox>
        </Grid>

        <!-- 表示名 -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Str_Dlg_Pad_DisplayName}" Grid.Column="0"/>
            <TextBox x:Name="TbDisplayName" Grid.Column="1"/>
        </Grid>

        <!-- パッド背景色 -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Str_Dlg_Pad_PadColor}" Grid.Column="0"/>
            <StackPanel Grid.Column="1" x:Name="BgColorSwatchesPanel"
                        Orientation="Horizontal"/>
        </Grid>

        <Separator Background="#383838" Margin="0,0,0,10"/>

        <!-- 音量 -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Str_Dlg_Pad_Volume}" Grid.Column="0"/>
            <TextBox x:Name="TbPadGain" Grid.Column="1"
                     KeyDown="NumericBox_KeyDown"
                     LostFocus="GainBox_LostFocus"
                     PreviewMouseDown="NumericBox_MouseDown"
                     PreviewMouseMove="NumericBox_MouseMove"
                     PreviewMouseUp="NumericBox_MouseUp"
                     PreviewMouseWheel="GainBox_MouseWheel"/>
            <Label Content="{StaticResource Str_Dlg_Pad_VolumeHint}" Grid.Column="2" Margin="8,0,0,0"/>
        </Grid>

        <Separator Background="#383838" Margin="0,0,0,10"/>

        <!-- 再生開始位置 -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Str_Dlg_Pad_StartPos}" Grid.Column="0"/>
            <TextBox x:Name="TbStartPos" Grid.Column="1"
                     KeyDown="NumericBox_KeyDown"
                     LostFocus="PosBox_LostFocus"
                     PreviewMouseDown="NumericBox_MouseDown"
                     PreviewMouseMove="NumericBox_MouseMove"
                     PreviewMouseUp="NumericBox_MouseUp"
                     PreviewMouseWheel="PosBox_MouseWheel"/>
            <Label x:Name="LblTotalTime" Content="" Grid.Column="2" Margin="8,0,0,0"/>
        </Grid>

        <!-- 再生終了位置 -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Str_Dlg_Pad_EndPos}" Grid.Column="0"/>
            <TextBox x:Name="TbEndPos" Grid.Column="1"
                     KeyDown="NumericBox_KeyDown"
                     LostFocus="PosBox_LostFocus"
                     PreviewMouseDown="NumericBox_MouseDown"
                     PreviewMouseMove="NumericBox_MouseMove"
                     PreviewMouseUp="NumericBox_MouseUp"
                     PreviewMouseWheel="PosBox_MouseWheel"/>
            <Label Content="{StaticResource Str_Dlg_Pad_EndHint}" Grid.Column="2" Margin="8,0,0,0"/>
        </Grid>

        <!-- ループ再生開始位置 -->
        <Grid x:Name="LoopStartRow" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LblLoopStart" Text="{StaticResource Str_Dlg_Pad_LoopStart}" Grid.Column="0"/>
            <TextBox x:Name="TbLoopStart" Grid.Column="1"
                     KeyDown="NumericBox_KeyDown"
                     LostFocus="PosBox_LostFocus"
                     PreviewMouseDown="NumericBox_MouseDown"
                     PreviewMouseMove="NumericBox_MouseMove"
                     PreviewMouseUp="NumericBox_MouseUp"
                     PreviewMouseWheel="PosBox_MouseWheel"/>
            <Label Content="{StaticResource Str_Dlg_Pad_LoopHint}" Grid.Column="2" Margin="8,0,0,0"/>
        </Grid>

        <Separator Background="#383838" Margin="0,0,0,10"/>

        <!-- 最後まで再生した後 -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Str_Dlg_Pad_AfterPlay}" Grid.Column="0"/>
            <ComboBox x:Name="CbAfterPlayback" Grid.Column="1"
                      ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                      SelectionChanged="CbAfterPlayback_SelectionChanged">
                <ComboBoxItem x:Name="CbAfterStop"    Content="{StaticResource Str_Dlg_Pad_AfterStop}"/>
                <ComboBoxItem x:Name="CbAfterFreeze"  Content="{StaticResource Str_Dlg_Pad_AfterFreeze}"/>
                <ComboBoxItem x:Name="CbAfterLoop"    Content="{StaticResource Str_Dlg_Pad_AfterLoop}"/>
            </ComboBox>
        </Grid>

        <!-- 再生中タップ -->
        <Grid x:Name="TapBehaviorRow" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Str_Dlg_Pad_TapBehavior}" Grid.Column="0"/>
            <ComboBox x:Name="CbTapBehavior" Grid.Column="1"
                      ItemContainerStyle="{StaticResource DarkComboBoxItem}">
                <ComboBoxItem Content="{StaticResource Str_Dlg_Pad_TapFade}"/>
                <ComboBoxItem Content="{StaticResource Str_Dlg_Pad_TapCut}"/>
                <ComboBoxItem x:Name="CbTapPauseResume" Content="{StaticResource Str_Dlg_Pad_TapPause}"/>
            </ComboBox>
        </Grid>

        <Separator Background="#383838" Margin="0,0,0,10"/>

        <!-- OK / キャンセル -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOk" Content="{StaticResource Str_Btn_OK}" Width="80" Margin="0,0,8,0"
                    Click="BtnOk_Click"
                    Background="#1C446E" BorderBrush="#3A9FFF" Foreground="White"
                    Padding="0,4" Cursor="Hand"/>
            <Button x:Name="BtnCancel" Content="{StaticResource Str_Btn_Cancel}" Width="80"
                    Click="BtnCancel_Click"
                    Background="#3C3C3C" BorderBrush="#555" Foreground="#CCC"
                    Padding="0,4" Cursor="Hand"/>
        </StackPanel>

    </StackPanel>
</Window>
