<UserControl x:Class="ikePon.UI.Controls.VFaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="90">

    <Border Background="#2A2A2A" BorderBrush="#404040" BorderThickness="1" CornerRadius="4" Padding="6,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="28"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 縦フェーダー -->
            <Slider x:Name="FaderSlider"
                    Grid.Column="0" Grid.Row="0"
                    Orientation="Vertical"
                    Minimum="0" Maximum="1"
                    Value="1"
                    TickFrequency="0.1"
                    HorizontalAlignment="Center"
                    Width="24"
                    Background="Transparent"
                    IsSnapToTickEnabled="False"
                    SmallChange="0.01"
                    LargeChange="0.1"
                    ValueChanged="FaderSlider_ValueChanged">
                <Slider.Resources>
                    <Style TargetType="Thumb">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="#5A5A5A" BorderBrush="#888" BorderThickness="1"
                                            Width="22" Height="12" CornerRadius="2"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="Track">
                        <Setter Property="Width" Value="4"/>
                    </Style>
                </Slider.Resources>
            </Slider>

            <!-- メモリボタン（右列）-->
            <StackPanel Grid.Column="1" Grid.Row="0"
                        VerticalAlignment="Stretch"
                        Margin="2,0,0,0">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Width" Value="22"/>
                        <Setter Property="Height" Value="18"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="FontSize" Value="9"/>
                        <Setter Property="Background" Value="#333"/>
                        <Setter Property="Foreground" Value="#888"/>
                        <Setter Property="BorderBrush" Value="#555"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4A4A4A"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#606060"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>
                <Button x:Name="Mem1" Content="M1" Tag="0" Click="Memory_Click" MouseRightButtonUp="Memory_RightClick"/>
                <Button x:Name="Mem2" Content="M2" Tag="1" Click="Memory_Click" MouseRightButtonUp="Memory_RightClick"/>
                <Button x:Name="Mem3" Content="M3" Tag="2" Click="Memory_Click" MouseRightButtonUp="Memory_RightClick"/>
                <Button x:Name="Mem4" Content="M4" Tag="3" Click="Memory_Click" MouseRightButtonUp="Memory_RightClick"/>
            </StackPanel>

            <!-- ラベル -->
            <TextBlock x:Name="FaderLabel"
                       Grid.Column="0" Grid.Row="1"
                       Text="MASTER"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </Grid>
    </Border>
</UserControl>
