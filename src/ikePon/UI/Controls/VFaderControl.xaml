<UserControl x:Class="ikePon.UI.Controls.VFaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="80">

    <Border Background="#252525" BorderBrush="#383838" BorderThickness="1" CornerRadius="4" Padding="4,8,4,6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>     <!-- フェーダー本体 -->
                <RowDefinition Height="Auto"/>  <!-- ラベル -->
                <RowDefinition Height="Auto"/>  <!-- メモリボタン -->
            </Grid.RowDefinitions>

            <!-- ====== フェーダー本体（目盛り＋スライダー） ====== -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>  <!-- 目盛り -->
                    <ColumnDefinition Width="*"/>   <!-- スライダー -->
                </Grid.ColumnDefinitions>

                <!-- 目盛り Canvas（コードビハインドで描画） -->
                <Canvas Grid.Column="0" x:Name="ScaleCanvas" Width="24"/>

                <!-- 縦フェーダー（カスタムテンプレート） -->
                <Slider Grid.Column="1"
                        x:Name="FaderSlider"
                        Orientation="Vertical"
                        Minimum="0"
                        Maximum="1.0"
                        Value="0.75"
                        SmallChange="0.01"
                        LargeChange="0.1"
                        HorizontalAlignment="Center"
                        Width="40"
                        ValueChanged="FaderSlider_ValueChanged"
                        SizeChanged="FaderSlider_SizeChanged"
                        MouseRightButtonUp="FaderSlider_RightClick"
                        MouseWheel="FaderSlider_MouseWheel">
                    <Slider.Template>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <!-- トラック背景ライン -->
                                <Rectangle x:Name="TrackBg"
                                           HorizontalAlignment="Center"
                                           Width="4"
                                           Fill="#181818"
                                           Stroke="#3A3A3A"
                                           StrokeThickness="1"
                                           RadiusX="2" RadiusY="2"
                                           Margin="0,10"/>

                                <!-- トラック -->
                                <Track x:Name="PART_Track" Orientation="Vertical">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Focusable="False"
                                                      Opacity="0"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Focusable="False"
                                                      Opacity="0"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border x:Name="ThumbBd"
                                                            Background="#5A5A5A"
                                                            BorderBrush="White"
                                                            BorderThickness="1"
                                                            CornerRadius="3"
                                                            Width="36" Height="20"
                                                            Cursor="SizeNS">
                                                        <!-- グリップ線 3本 -->
                                                        <StackPanel VerticalAlignment="Center" Margin="6,0">
                                                            <Rectangle x:Name="Grip1" Height="1" Fill="White" Margin="0,1"/>
                                                            <Rectangle x:Name="Grip2" Height="1" Fill="White" Margin="0,2"/>
                                                            <Rectangle x:Name="Grip3" Height="1" Fill="White" Margin="0,2"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbBd" Property="Background" Value="#6A6A6A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbBd" Property="Background" Value="#787878"/>
                                                        </Trigger>
                                                        <!-- 矢印キーで操作可能な時（スライダーがキーボードフォーカスを持つ時）黄色 -->
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Slider}}, Path=IsKeyboardFocusWithin}" Value="True">
                                                            <Setter TargetName="ThumbBd" Property="BorderBrush" Value="#FFD700"/>
                                                            <Setter TargetName="ThumbBd" Property="BorderThickness" Value="2.5"/>
                                                            <Setter TargetName="Grip1" Property="Fill" Value="#FFD700"/>
                                                            <Setter TargetName="Grip2" Property="Fill" Value="#FFD700"/>
                                                            <Setter TargetName="Grip3" Property="Fill" Value="#FFD700"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Slider.Template>
                </Slider>
            </Grid>

            <!-- ====== ラベル ====== -->
            <TextBlock x:Name="FaderLabel"
                       Grid.Row="1"
                       Text="MASTER"
                       FontSize="12" FontWeight="Bold"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,4"/>

            <!-- ====== メモリボタン（2×2） ====== -->
            <UniformGrid Grid.Row="2" Rows="2" Columns="2" Margin="0,0,0,0">
                <UniformGrid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="Margin" Value="1,1"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Background" Value="#2E2E2E"/>
                        <Setter Property="Foreground" Value="#666"/>
                        <Setter Property="BorderBrush" Value="#444"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#444"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#555"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </UniformGrid.Resources>
                <Button x:Name="Mem1" Content="M1" Tag="0" Click="Memory_Click" MouseRightButtonUp="Memory_RightClick"/>
                <Button x:Name="Mem2" Content="M2" Tag="1" Click="Memory_Click" MouseRightButtonUp="Memory_RightClick"/>
                <Button x:Name="Mem3" Content="M3" Tag="2" Click="Memory_Click" MouseRightButtonUp="Memory_RightClick"/>
                <Button x:Name="Mem4" Content="M4" Tag="3" Click="Memory_Click" MouseRightButtonUp="Memory_RightClick"/>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>
