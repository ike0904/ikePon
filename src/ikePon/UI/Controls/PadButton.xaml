<UserControl x:Class="ikePon.UI.Controls.PadButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="100" MinHeight="90">

    <Border x:Name="BorderRoot"
            Background="#3C3C3C"
            BorderBrush="#555555"
            BorderThickness="2"
            CornerRadius="4"
            Margin="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
            </Grid.RowDefinitions>

            <!-- メインコンテンツ -->
            <Grid Grid.Row="0" Margin="4,4,4,2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- カテゴリバッジ -->
                <Border Grid.Row="0"
                        x:Name="CategoryBadge"
                        Background="#444"
                        CornerRadius="2"
                        Padding="4,1"
                        HorizontalAlignment="Left">
                    <TextBlock x:Name="CategoryLabel"
                               Text="BGM"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#999"
                               />
                </Border>

                <!-- ファイル名 -->
                <TextBlock x:Name="FileNameLabel"
                           Grid.Row="1"
                           Text="---"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,4"/>

                <!-- キーラベル（バンクボタンと統一したバッジスタイル） -->
                <Border Grid.Row="2"
                        x:Name="KeyBadge"
                        Background="#1C1C1C"
                        BorderBrush="#4A4A4A"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="4,1"
                        HorizontalAlignment="Right"
                        Margin="0,1,2,0">
                    <TextBlock x:Name="KeyLabel"
                               Text="1"
                               FontSize="16"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               Foreground="#AAAAAA"/>
                </Border>
            </Grid>

            <!-- プログレスバー（下端） -->
            <Border Grid.Row="1"
                    Background="#222"
                    CornerRadius="0,0,2,2">
                <Rectangle x:Name="ProgressBar"
                           HorizontalAlignment="Left"
                           Width="0"
                           Fill="#3A7FC1"
                           RadiusX="2" RadiusY="2"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
