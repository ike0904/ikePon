<Window x:Class="ikePon.UI.Windows.MovieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="ikePon Movie"
        Background="Black"
        MinWidth="320" MinHeight="180"
        Width="1280" Height="720"
        ShowInTaskbar="True"
        ShowActivated="False"
        Closing="Window_Closing"
        MouseDoubleClick="Window_MouseDoubleClick">
    <Grid Background="Black">
        <!-- 動画（LibVLCSharp、常に表示して HWND を確保） -->
        <vlc:VideoView x:Name="VideoView"/>
        <!-- フェードアウト用オーバーレイ（黒を重ねて暗転） -->
        <Rectangle x:Name="FadeOverlay"
                   Fill="Black"
                   Opacity="0"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"/>
        <!-- スタンバイレイヤー（非再生時に最前面で覆う） -->
        <Grid x:Name="StandbyLayer" Background="Black">
            <Image x:Name="StandbyImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
