<Window x:Class="ikePon.UI.Windows.MovieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ikePon Movie"
        Background="Black"
        MinWidth="320" MinHeight="180"
        Width="1280" Height="720"
        ShowInTaskbar="True"
        ShowActivated="False"
        Closing="Window_Closing"
        MouseDoubleClick="Window_MouseDoubleClick">
    <Grid Background="Black">
        <!-- スタンバイ画像（常に表示、動画の下に配置） -->
        <Image x:Name="StandbyImage"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
        <!-- 動画（MediaElement で描画、再生中のみ表示。音声はNAudio側で再生するためミュート） -->
        <MediaElement x:Name="VideoPlayer"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="Uniform"
                      IsMuted="True"
                      Visibility="Collapsed"
                      MediaOpened="VideoPlayer_MediaOpened"
                      MediaEnded="VideoPlayer_MediaEnded"
                      MediaFailed="VideoPlayer_MediaFailed"/>
    </Grid>
</Window>
