<Window x:Class="ikePon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:ikePon.UI.Controls"
        Title="ikePon v1.0.0"
        Icon="Assets/ikepon_icon.png"
        Background="#272727"
        MinWidth="1200" MinHeight="720"
        Width="1200" Height="720"
        WindowStyle="SingleBorderWindow"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        Closing="Window_Closing"
        MouseDown="MainWindow_PreviewMouseDown"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- メニューバー -->
            <RowDefinition Height="62"/>    <!-- インフォ+パニック -->
            <RowDefinition Height="*"/>     <!-- メインエリア -->
        </Grid.RowDefinitions>

        <!-- ====== メニューバー ====== -->
        <Menu Grid.Row="0" Background="#1A1A1A" Foreground="#CCCCCC" FontSize="12">
            <Menu.Resources>
                <!-- ControlTemplate でポップアップ背景を直接指定（SystemColors 上書きは Windows 11 では効かない） -->
                <Style TargetType="MenuItem">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="Padding"    Value="8,5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderThickness="0"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter ContentSource="Header"
                                                              RecognizesAccessKey="True"
                                                              VerticalAlignment="Center"/>
                                            <TextBlock x:Name="Igt"
                                                       Grid.Column="1"
                                                       Text="{TemplateBinding InputGestureText}"
                                                       Foreground="#AAA"
                                                       Margin="24,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>
                                    <!-- サブメニュー用ポップアップ（背景を直接 #1E1E1E に指定） -->
                                    <Popup x:Name="PART_Popup"
                                           Placement="Bottom"
                                           IsOpen="{TemplateBinding IsSubmenuOpen}"
                                           AllowsTransparency="True"
                                           Focusable="False">
                                        <Border Background="#1E1E1E" BorderBrush="#444"
                                                BorderThickness="1" Padding="0,2">
                                            <ItemsPresenter/>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <!-- SubmenuItem: ショートカットキー表示 -->
                                    <Trigger Property="Role" Value="SubmenuItem">
                                        <Setter TargetName="Igt" Property="Visibility" Value="Visible"/>
                                    </Trigger>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2E2E2E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#555"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="Separator">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Separator">
                                <Border Height="1" Background="#444" Margin="6,2"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Menu.Resources>
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規プロジェクト(_N)" InputGestureText="Ctrl+N" Click="Menu_New"/>
                <MenuItem Header="開く(_O)..."         InputGestureText="Ctrl+O" Click="Menu_Open"/>
                <Separator Background="#444"/>
                <MenuItem Header="上書き保存(_S)"      InputGestureText="Ctrl+S" Click="Menu_Save"/>
                <MenuItem Header="名前を付けて保存(_A)..."                        Click="Menu_SaveAs"/>
                <Separator Background="#444"/>
                <MenuItem Header="終了(_X)"            Click="Menu_Exit"/>
            </MenuItem>
            <MenuItem Header="設定(_S)">
                <MenuItem Header="設定..." InputGestureText="Ctrl+E" Click="Menu_Settings"/>
            </MenuItem>
        </Menu>

        <!-- ====== インフォメーション・パニックエリア ====== -->
        <Border Grid.Row="1" Background="#1A1A1A" BorderBrush="#404040" BorderThickness="1"
                CornerRadius="4" Margin="6,4,6,4">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="144"/>
                    <ColumnDefinition Width="132"/>
                </Grid.ColumnDefinitions>

                <!-- ALL CUT ボタン（左側） -->
                <Grid Grid.Column="0">
                    <Button x:Name="PanicButton"
                            Height="44"
                            Margin="0,0,2,0"
                            Cursor="Hand"
                            Focusable="False"
                            Click="PanicButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="#BB1111"
                                                    BorderBrush="#FF4444" BorderThickness="2" CornerRadius="6">
                                                <Grid>
                                                    <TextBlock x:Name="PanicText"
                                                               Text="ALL CUT"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Margin="0"
                                                               Panel.ZIndex="1"/>
                                                    <Border Background="#1C1C1C" BorderBrush="#AAAAAA"
                                                            BorderThickness="1" CornerRadius="2"
                                                            Padding="4,1"
                                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                            Margin="0,0,4,3"
                                                            RenderTransformOrigin="1,0.5">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="0.7" ScaleY="1.0"/>
                                                        </Border.RenderTransform>
                                                        <TextBlock Text="ESC"
                                                                   FontSize="16" FontWeight="Bold"
                                                                   FontFamily="Consolas"
                                                                   Foreground="#AAAAAA"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#DD1111"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF2222"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- ALL FADEボタン（ALL CUTの右隣） -->
                <Button x:Name="FadeCutButton"
                        Grid.Column="1"
                        Height="44"
                        Margin="2,0,0,0"
                        Cursor="Hand"
                        Focusable="False"
                        Click="FadeCutButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="FadeCutBd" Background="#1133BB"
                                                BorderBrush="#4488FF" BorderThickness="2" CornerRadius="6">
                                            <Grid>
                                                <TextBlock x:Name="FadeCutText"
                                                           Text="ALL FADE"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Panel.ZIndex="1"/>
                                                <Border Background="#1C1C1C" BorderBrush="#AAAAAA"
                                                        BorderThickness="1" CornerRadius="2"
                                                        Padding="4,1"
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                        Margin="0,0,4,3"
                                                        RenderTransformOrigin="1,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="0.7" ScaleY="1.0"/>
                                                    </Border.RenderTransform>
                                                    <TextBlock Text="SPC"
                                                               FontSize="16" FontWeight="Bold"
                                                               FontFamily="Consolas"
                                                               Foreground="#AAAAAA"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="FadeCutBd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="FadeCutBd" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- PAUSEボタン（ALL FADEの右隣） -->
                <Button x:Name="PauseAllButton"
                        Grid.Column="2"
                        Height="44"
                        Margin="2,0,0,0"
                        Cursor="Hand"
                        Focusable="False"
                        Click="PauseAllButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="PauseBd" Background="#1A6B1A"
                                                BorderBrush="#44CC44" BorderThickness="2" CornerRadius="6">
                                            <Grid>
                                                <TextBlock x:Name="PauseText"
                                                           Text="PAUSE"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Panel.ZIndex="1"/>
                                                <Border Background="#1C1C1C" BorderBrush="#AAAAAA"
                                                        BorderThickness="1" CornerRadius="2"
                                                        Padding="4,1"
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                        Margin="0,0,4,3"
                                                        RenderTransformOrigin="1,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="0.7" ScaleY="1.0"/>
                                                    </Border.RenderTransform>
                                                    <TextBlock Text="ENT"
                                                               FontSize="16" FontWeight="Bold"
                                                               FontFamily="Consolas"
                                                               Foreground="#AAAAAA"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PauseBd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="PauseBd" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- FULLボタン（右端から2番目） -->
                <Button x:Name="FullButton"
                        Grid.Column="4"
                        Height="44"
                        Margin="16,0,0,0"
                        Cursor="Hand"
                        Focusable="False"
                        Click="FullButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="FullBd" Background="#303030"
                                                BorderBrush="#555555" BorderThickness="2" CornerRadius="6">
                                            <Grid>
                                                <TextBlock x:Name="FullText"
                                                           Text="FULL SCR"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Panel.ZIndex="1"/>
                                                <Border Background="#1C1C1C" BorderBrush="#AAAAAA"
                                                        BorderThickness="1" CornerRadius="2"
                                                        Padding="4,1"
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                        Margin="0,0,4,3">
                                                    <TextBlock Text="0"
                                                               FontSize="16" FontWeight="Bold"
                                                               FontFamily="Consolas"
                                                               Foreground="#AAAAAA"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="FullBd" Property="Background" Value="#404040"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="FullBd" Property="Background" Value="#505050"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- DISPLAYボタン（右端） -->
                <Button x:Name="DispButton"
                        Grid.Column="5"
                        Height="44"
                        Margin="4,0,0,0"
                        Cursor="Hand"
                        Focusable="False"
                        Click="DispButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="DispBd" Background="#303030"
                                                BorderBrush="#555555" BorderThickness="2" CornerRadius="6">
                                            <Grid>
                                                <TextBlock x:Name="DispText"
                                                           Text="DISPLAY"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Panel.ZIndex="1"/>
                                                <Border Background="#1C1C1C" BorderBrush="#AAAAAA"
                                                        BorderThickness="1" CornerRadius="2"
                                                        Padding="4,1"
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                        Margin="0,0,4,3">
                                                    <TextBlock Text="-"
                                                               FontSize="16" FontWeight="Bold"
                                                               FontFamily="Consolas"
                                                               Foreground="#AAAAAA"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="DispBd" Property="Background" Value="#404040"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="DispBd" Property="Background" Value="#505050"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- インフォメーションエリア（中央） -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <Border x:Name="InfoLine2Border" Background="Transparent"
                            CornerRadius="3" Padding="4,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="InfoLine2"
                                       Grid.Column="0"
                                       Text="準備完了"
                                       FontSize="12"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <!-- バンク切り替え確認ボタン（確認中のみ表示） -->
                            <StackPanel x:Name="BankConfirmPanel"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Visibility="Collapsed"
                                        Margin="12,0,0,0">
                                <Button x:Name="BankYesBtn"
                                        Content="YES"
                                        Width="60" Height="22"
                                        Margin="0,0,6,0"
                                        FontSize="11" FontWeight="Bold"
                                        Foreground="White"
                                        Cursor="Hand"
                                        Focusable="False"
                                        Click="BankYesBtn_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="#1A5C1A" BorderBrush="#33AA33"
                                                                BorderThickness="1" CornerRadius="3">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#227722"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#33AA33"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button x:Name="BankNoBtn"
                                        Content="NO"
                                        Width="60" Height="22"
                                        FontSize="11" FontWeight="Bold"
                                        Foreground="White"
                                        Cursor="Hand"
                                        Focusable="False"
                                        Click="BankNoBtn_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="#5C1A1A" BorderBrush="#AA3333"
                                                                BorderThickness="1" CornerRadius="3">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#772222"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#AA3333"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ====== メインエリア ====== -->
        <Grid Grid.Row="2" Margin="6,0,6,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="540"/>
                <ColumnDefinition Width="380" MinWidth="340"/>
            </Grid.ColumnDefinitions>

            <!-- 左: 4×4 キーパッド -->
            <Border Grid.Column="0" Background="#212121" BorderBrush="#3A3A3A"
                    BorderThickness="1" CornerRadius="4" Margin="0,0,4,0" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="KEYPAD" FontSize="12" Foreground="#AAAAAA"
                               FontWeight="Bold" Margin="2,0,0,4"/>
                    <UniformGrid x:Name="PadGrid" Grid.Row="1" Rows="4" Columns="4"/>
                </Grid>
            </Border>

            <!-- 右: バンク + ミキサー -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- バンク切り替え -->
                <Border Grid.Row="0" Background="#212121" BorderBrush="#3A3A3A"
                        BorderThickness="1" CornerRadius="4" Margin="0,0,0,4" Padding="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="BANK" FontSize="12" Foreground="#AAAAAA"
                                   FontWeight="Bold" Margin="2,0,0,4"/>
                        <UniformGrid x:Name="BankGrid" Grid.Row="1" Rows="4" Columns="2"/>
                    </Grid>
                </Border>

                <!-- ミキサー -->
                <Border Grid.Row="1" Background="#212121" BorderBrush="#3A3A3A"
                        BorderThickness="1" CornerRadius="4" Padding="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="MIXER" FontSize="12" Foreground="#AAAAAA"
                                   FontWeight="Bold" Margin="2,0,0,4"/>
                        <UniformGrid x:Name="MixerGrid" Grid.Row="1" Rows="1" Columns="4"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
